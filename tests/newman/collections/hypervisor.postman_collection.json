    {
      "name": "HV-REG-NEG-BAD-ZONE — RegisterHypervisor с несуществующим zone_id → InvalidArgument/FailedPrecondition (3/9), без 500",
      "description": "class:NEG | priority:P1",
      "item": [
        {
          "name": "reg-bad-zone",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/kacho.cloud.compute.v1.InternalHypervisorService/RegisterHypervisor",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "kacho.cloud.compute.v1.InternalHypervisorService",
                "RegisterHypervisor"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\"id\": \"nm-hv-badz-{{runId}}\", \"zoneId\": \"ru-central1-zzz\", \"capacity\": {\"vcpus\": 64, \"memoryBytes\": 274877906944, \"instances\": 40}}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('not 500', () => pm.expect(pm.response.code).to.not.eql(500));",
                  "pm.test('rejected 400 (or 200 if zone not validated — then cleanup)', () => pm.expect(pm.response.code).to.be.oneOf([400, 200]));",
                  "if (pm.response.code === 400) { const j = pm.response.json(); pm.test('grpc code 3 or 9', () => pm.expect(j.code, JSON.stringify(j)).to.be.oneOf([3, 9])); }",
                  "if (pm.response.code === 200) { pm.environment.set('hvId', pm.response.json().id); }"
                ]
              }
            }
          ]
        },
        {
          "name": "cleanup-if-created",
