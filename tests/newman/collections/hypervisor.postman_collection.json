{
  "info": {
    "_postman_id": "75a344ca-d47a-494f-a3a1-b312b17efdef",
    "name": "kacho-compute / newman / hypervisor",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.environment.get('runId') || pm.environment.get('runId') === '') {",
          "  // runId формат: только [a-z0-9], без точки, начинается с буквы — чтобы проходить compute name regex",
          "  const t = Date.now().toString(36);",
          "  const r = Math.floor(Math.random() * 1e9).toString(36);",
          "  pm.environment.set('runId', ('r' + t + r).replace(/[^a-z0-9]/g, '').slice(0, 11));",
          "}",
          "pm.environment.set('_suiteFolderId', pm.environment.get('existingProjectId'));",
          "pm.environment.set('_suiteFolderCrossId', pm.environment.get('existingProjectCrossId'));"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "HV-REG-OK — RegisterHypervisor(zone_id, fqdn, node_index via server, capacity) → 200, возвращает Hypervisor с id, READY, capacity",
      "description": "class:CRUD | priority:P1",
      "item": [
        {
          "name": "register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/kacho.cloud.compute.v1.InternalHypervisorService/RegisterHypervisor",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "kacho.cloud.compute.v1.InternalHypervisorService",
                "RegisterHypervisor"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\"id\": \"nm-hv-reg-{{runId}}\", \"zoneId\": \"ru-central1-a\", \"fqdn\": \"nm-hv-reg-{{runId}}.kacho.local\", \"capacity\": {\"vcpus\": 64, \"memoryBytes\": 274877906944, \"instances\": 40}}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', () => pm.expect(pm.response.code).to.eql(200));",
                  "const j = pm.response.json();",
                  "pm.test('id present', () => pm.expect(j.id, JSON.stringify(j)).to.be.a('string').and.length.greaterThan(0));",
                  "pm.test('id echoed', () => pm.expect(j.id).to.eql('nm-hv-reg-' + pm.environment.get('runId')));",
                  "pm.test('zoneId matches', () => pm.expect(j.zoneId).to.eql('ru-central1-a'));",
                  "pm.test('state READY', () => pm.expect(j.state).to.eql('READY'));",
                  "pm.test('nodeIndex is set (uint32)', () => pm.expect(Number(j.nodeIndex)).to.be.a('number').and.at.least(0));",
                  "pm.test('capacity vcpus echoed', () => pm.expect(String(j.capacity && j.capacity.vcpus)).to.eql('64'));",
                  "pm.test('createdAt set', () => pm.expect(j.createdAt).to.be.a('string'));",
                  "pm.environment.set('hvId', j.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "cleanup-dereg",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/kacho.cloud.compute.v1.InternalHypervisorService/DeregisterHypervisor",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "kacho.cloud.compute.v1.InternalHypervisorService",
                "DeregisterHypervisor"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\"hypervisorId\": \"{{hvId}}\"}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        }
      ]
    },
