{
  "info": {
    "_postman_id": "d922dd2c-9052-4daf-b210-2b96e435731f",
    "name": "kacho-compute / newman / operation",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.environment.get('runId') || pm.environment.get('runId') === '') {",
          "  // runId формат: только [a-z0-9], без точки, начинается с буквы — чтобы проходить compute name regex",
          "  const t = Date.now().toString(36);",
          "  const r = Math.floor(Math.random() * 1e9).toString(36);",
          "  pm.environment.set('runId', ('r' + t + r).replace(/[^a-z0-9]/g, '').slice(0, 11));",
          "}",
          "pm.environment.set('_suiteFolderId', pm.environment.get('existingProjectId'));",
          "pm.environment.set('_suiteFolderCrossId', pm.environment.get('existingProjectCrossId'));"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "OP-GET-CRUD-OK — Get свежесозданной operation (после Disk.Create) → done=true, has response, metadata.diskId",
      "description": "class:CRUD | priority:P1",
      "item": [
        {
          "name": "create-trigger",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/compute/v1/disks",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "compute",
                "v1",
                "disks"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\"projectId\": \"{{_suiteFolderId}}\", \"name\": \"disk-opget-{{runId}}\", \"zoneId\": \"{{existingZoneId}}\", \"size\": 10737418240}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', () => pm.expect(pm.response.code).to.eql(200));",
                  "try {",
                  "  const j = pm.response.json();",
                  "  const v = (j.id);",
                  "  if (v !== undefined && v !== null) pm.environment.set('opId', String(v));",
                  "} catch (e) {}",
                  "try {",
                  "  const j = pm.response.json();",
                  "  const v = (j.metadata && j.metadata.diskId);",
                  "  if (v !== undefined && v !== null) pm.environment.set('diskId', String(v));",
                  "} catch (e) {}"
                ]
              }
            }
          ]
        },
        {
          "name": "poll-op",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/operations/{{opId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "operations",
                "{{opId}}"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('poll status 200', () => pm.expect(pm.response.code).to.eql(200));",
                  "const j = pm.response.json();",
                  "const pc = parseInt(pm.environment.get('_pollCount') || '0', 10);",
                  "if (!j.done && pc < 8) {",
                  "  pm.environment.set('_pollCount', String(pc + 1));",
                  "  postman.setNextRequest(pm.info.requestName);",
                  "  return;",
                  "}",
                  "pm.environment.unset('_pollCount');",
                  "pm.test('operation done', () => pm.expect(j.done, JSON.stringify(j)).to.eql(true));",
                  "if (j.error) pm.environment.set('lastOpError', JSON.stringify(j.error));",
                  "else pm.environment.unset('lastOpError');",
                  "if (j.response) pm.environment.set('lastOpResponse', JSON.stringify(j.response));"
                ]
              }
            }
          ]
        },
        {
          "name": "get-op",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/operations/{{opId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "operations",
                "{{opId}}"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', () => pm.expect(pm.response.code).to.eql(200));",
                  "const j = pm.response.json();",
                  "pm.test('id matches & epd prefix', () => { pm.expect(j.id).to.eql(pm.environment.get('opId')); pm.expect(j.id).to.match(/^epd/); });",
                  "pm.test('done=true', () => pm.expect(j.done).to.eql(true));",
                  "pm.test('has response (no error)', () => { pm.expect(j.response).to.be.an('object'); pm.expect(j.error).to.be.oneOf([undefined, null]); });",
                  "pm.test('metadata has diskId (epd...)', () => pm.expect(j.metadata && j.metadata.diskId).to.match(/^epd/));",
                  "pm.test('createdAt present', () => pm.expect(j.createdAt).to.be.a('string'));"
                ]
              }
            }
          ]
        },
