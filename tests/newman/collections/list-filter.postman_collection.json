    {
      "name": "LF-INST-GET-NOLEAK-404-NOT-403 — [D-44] PA1 Get well-formed-но-отсутствующего instanceId → 404 NOT_FOUND (no-leak, не 403)",
      "description": "class:AUTHZ | class:NEG | class:LST | priority:P0",
      "item": [
        {
          "name": "get-absent",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/compute/v1/instances/{{garbageComputeId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "compute",
                "v1",
                "instances",
                "{{garbageComputeId}}"
              ]
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// KAC-122 authz-deny: bearer from env 'jwtProjectAdminA1'",
                  "const __t = pm.environment.get('jwtProjectAdminA1') || pm.variables.get('jwtProjectAdminA1') || '';",
                  "if (__t) {",
                  "  pm.request.headers.upsert({key: 'Authorization', value: 'Bearer ' + __t});",
                  "} else {",
                  "  pm.request.headers.remove('Authorization');",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 404', () => pm.expect(pm.response.code).to.eql(404));",
                  "pm.test('grpc code 5 (NOT_FOUND)', () => {",
                  "  const j = pm.response.json();",
                  "  pm.expect(j.code, JSON.stringify(j)).to.eql(5);",
                  "});",
                  "pm.test('[D-44] no-leak: NOT_FOUND, not PERMISSION_DENIED', () => pm.expect(pm.response.json().code).to.not.eql(7));"
                ]
              }
            }
          ]
        }
      ]
    },
