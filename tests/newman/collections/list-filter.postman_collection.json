{
  "info": {
    "_postman_id": "2490ac4b-03fb-4705-909d-57ee91ba929c",
    "name": "kacho-compute / newman / list-filter",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.environment.get('runId') || pm.environment.get('runId') === '') {",
          "  // runId формат: только [a-z0-9], без точки, начинается с буквы — чтобы проходить compute name regex",
          "  const t = Date.now().toString(36);",
          "  const r = Math.floor(Math.random() * 1e9).toString(36);",
          "  pm.environment.set('runId', ('r' + t + r).replace(/[^a-z0-9]/g, '').slice(0, 11));",
          "}",
          "pm.environment.set('_suiteFolderId', pm.environment.get('existingProjectId'));",
          "pm.environment.set('_suiteFolderCrossId', pm.environment.get('existingProjectCrossId'));"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "LF-INST-LST-READ-ENFORCE-OWNER-SEES-OWN — [D-40/D-45] PA1 создаёт instance в project-A1 и видит его в filtered List (read==enforce, verb→viewer)",
      "description": "class:AUTHZ | class:POS | class:LST | priority:P0",
      "item": [
        {
          "name": "create-own",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/compute/v1/instances",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "compute",
                "v1",
                "instances"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\"projectId\": \"{{projectA1Id}}\", \"name\": \"lf-inst-own-{{runId}}\", \"zoneId\": \"ru-central1-a\", \"platformId\": \"standard-v3\", \"resourcesSpec\": {\"memory\": \"1073741824\", \"cores\": 2}, \"bootDiskSpec\": {\"diskSpec\": {\"size\": \"8589934592\", \"typeId\": \"network-ssd\"}}}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// KAC-122 authz-deny: bearer from env 'jwtProjectAdminA1'",
                  "const __t = pm.environment.get('jwtProjectAdminA1') || pm.variables.get('jwtProjectAdminA1') || '';",
                  "if (__t) {",
                  "  pm.request.headers.upsert({key: 'Authorization', value: 'Bearer ' + __t});",
                  "} else {",
                  "  pm.request.headers.remove('Authorization');",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', () => pm.expect(pm.response.code).to.eql(200));",
                  "try {",
                  "  const j = pm.response.json();",
                  "  const v = (j.id);",
                  "  if (v !== undefined && v !== null) pm.environment.set('opId', String(v));",
                  "} catch (e) {}",
                  "try {",
                  "  const j = pm.response.json();",
                  "  const v = (j.metadata && j.metadata.instanceId);",
                  "  if (v !== undefined && v !== null) pm.environment.set('lfInstanceId', String(v));",
                  "} catch (e) {}"
                ]
              }
            }
          ]
        },
        {
          "name": "poll-op",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/operations/{{opId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "operations",
                "{{opId}}"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('poll status 200', () => pm.expect(pm.response.code).to.eql(200));",
                  "const j = pm.response.json();",
                  "const pc = parseInt(pm.environment.get('_pollCount') || '0', 10);",
                  "if (!j.done && pc < 8) {",
                  "  pm.environment.set('_pollCount', String(pc + 1));",
                  "  postman.setNextRequest(pm.info.requestName);",
                  "  return;",
                  "}",
                  "pm.environment.unset('_pollCount');",
                  "pm.test('operation done', () => pm.expect(j.done, JSON.stringify(j)).to.eql(true));",
                  "if (j.error) pm.environment.set('lastOpError', JSON.stringify(j.error));",
                  "else pm.environment.unset('lastOpError');",
                  "if (j.response) pm.environment.set('lastOpResponse', JSON.stringify(j.response));"
                ]
              }
            }
          ]
        },
        {
          "name": "assert-op-success",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/operations/{{opId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "operations",
                "{{opId}}"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const j = pm.response.json();",
                  "pm.test('operation done', () => pm.expect(j.done, JSON.stringify(j)).to.eql(true));",
                  "pm.test('operation succeeded (response, no error)', () => pm.expect(Boolean(j.response) && !j.error, JSON.stringify(j)).to.eql(true));"
                ]
              }
            }
          ]
        },
